{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/Praefixum.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "run demo",
            "command": "dotnet",
            "type": "process",
            "args": [
                "run",
                "--project",
                "${workspaceFolder}/Praefixum.Demo/Praefixum.Demo.csproj"
            ],
            "problemMatcher": "$msCompile",
            "dependsOn": [
                "build"
            ]
        },
        {
            "label": "test",
            "command": "dotnet",
            "type": "process",
            "args": [
                "test",
                "${workspaceFolder}/Praefixum.Tests/Praefixum.Tests.csproj",
                "--verbosity",
                "normal"
            ],
            "problemMatcher": "$msCompile",
            "dependsOn": [
                "build"
            ]
        }
    ]
}
